# ── Backend environment (copy to backend/.env and fill in) ──
# Never commit the real .env. Keep secrets out of git.

# Database — Supabase Postgres connection string (with pgvector enabled)
# e.g. postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres
DATABASE_URL=

# Auth
JWT_SECRET=

# LLM (DeepSeek)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# OCR (Surya remote via Colab/ngrok); leave blank to use local fallback
COLAB_OCR_URL=

# PDF rendering (Poppler bin path), e.g. C:\poppler\bin
POPPLER_PATH=

# Email (SMTP) — used for verification / notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

# URLs
APP_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Supabase Storage (added in Iter 0/1)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=documents

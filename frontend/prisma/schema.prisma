generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Iteration 8 — RBAC: admin | accountant | owner | auditor (FR-32)
enum UserRole {
  owner
  accountant
  admin
  auditor
}

model User {
  id                 String              @id @default(cuid())
  fullName           String?
  companyName        String?
  email              String              @unique
  password           String
  resetToken         String?
  resetTokenExpiry   DateTime?
  phone              String?
  jobTitle           String?
  country            String?
  businessUnit       String?
  department         String?
  primaryLanguage    String?             @default("en")
  profileImage      String?              @db.Text
  autoClassify       Boolean             @default(true)
  twoFactorEnabled   Boolean             @default(false)
  sessionVersion     Int                 @default(1)
  role               UserRole            @default(owner)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  activityLogs       ActivityLog[]
  loginVerifications LoginVerification[]
  trustedDevices     TrustedDevice[]
  uploadedFiles      UploadedFile[]
}

model TrustedDevice {
  id          String   @id @default(cuid())
  userId      String
  deviceToken String   @unique
  deviceName  String?
  ipAddress   String?
  userAgent   String?
  trustedAt   DateTime @default(now())
  lastUsedAt  DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LoginVerification {
  id          String   @id @default(cuid())
  userId      String
  token       String   @unique
  deviceToken String
  deviceName  String?
  ipAddress   String?
  userAgent   String?
  expiresAt   DateTime
  used        Boolean  @default(false)
  trusted     Boolean  @default(false)
  approved    Boolean  @default(false)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  type      String
  content   String
  response  String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UploadedFile {
  id        String   @id @default(cuid())
  userId    String
  fileName  String
  fileUrl   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model query_history {
  id           String    @id @db.Uuid
  user_id      String
  company_name String?
  question     String
  answer       String?
  explanation  String?
  metrics      Json?
  evidence     Json?
  source_file  String?
  created_at   DateTime? @default(now()) @db.Timestamp(6)
}

// ─────────────────────────────────────────────────────────────────────
// Iteration 1 — financial document store (replaces the CSV) + C4 tables.
// tenantId == User.id (string/cuid). Backend accesses these via psycopg.
// See docs/design/iter-1-schema.md.
// ─────────────────────────────────────────────────────────────────────

model FinancialDocument {
  id                 String     @id @default(cuid())
  tenantId           String
  documentId         String
  documentType       String?
  orderId            String?
  flowType           String?
  effectiveFlowType  String?
  companyName        String?
  supplierName       String?
  docDate            String?
  rawTotalAmount     Decimal?   @db.Decimal(14, 2)
  finalTotalAmount   Decimal?   @db.Decimal(14, 2)
  totalStatus        String?
  payableAmount      Decimal?   @db.Decimal(14, 2)
  cashReturn         Decimal?   @db.Decimal(14, 2)
  currency           String?    @default("LKR")
  receivedStatus     String?
  paidStatus         String?
  status             String?
  language           String?
  rawText            String?
  correctedText      String?
  structuredJson     Json?
  correctionJson     Json?
  arithmeticStatus   String?
  arithmeticJson     Json?
  ocrSelectedVersion String?
  safeboxJson        String?   @db.Text
  spatialChunksJson  String?   @db.Text
  deletedAt          DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  lineItems          LineItem[]

  @@unique([tenantId, documentId])
  @@index([tenantId])
  @@index([tenantId, docDate])
  @@index([tenantId, supplierName])
}

model LineItem {
  id          String            @id @default(cuid())
  tenantId    String
  documentRef String
  lineNo      Int
  description String?
  qty         Decimal?          @db.Decimal(14, 3)
  unitPrice   Decimal?          @db.Decimal(14, 2)
  total       Decimal?          @db.Decimal(14, 2)
  tax         Decimal?          @db.Decimal(14, 2)
  discount    Decimal?          @db.Decimal(14, 2)
  currency    String?
  rawJson     Json?
  document    FinancialDocument @relation(fields: [documentRef], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([documentRef])
}

model Entity {
  id            String        @id @default(cuid())
  tenantId      String
  entityType    String
  canonicalName String
  rawName       String?
  createdAt     DateTime      @default(now())
  aliases       EntityAlias[]

  @@unique([tenantId, entityType, canonicalName])
  @@index([tenantId, entityType])
}

model EntityAlias {
  id        String   @id @default(cuid())
  tenantId  String
  entityRef String
  aliasText String
  score     Float?
  method    String
  createdAt DateTime @default(now())
  entity    Entity   @relation(fields: [entityRef], references: [id], onDelete: Cascade)

  @@index([tenantId, entityRef])
  @@index([tenantId, aliasText])
}

model DocLink {
  id          String   @id @default(cuid())
  tenantId    String
  fromDocId   String
  linkType    String
  toEntityRef String?
  toDocId     String?
  confidence  Float    @default(1.0)
  evidence    Json?
  createdAt   DateTime @default(now())

  @@index([tenantId, fromDocId])
  @@index([tenantId, toDocId])
  @@index([tenantId, linkType])
}

// ---- Iteration 4: vector embeddings over C2 SpatialChunks ----
// See docs/design/iter-4-schema.md. `embedding` is Unsupported because Prisma
// has no native pgvector scalar; the real column type + HNSW index are in the
// hand-authored migration SQL.
model ChunkEmbedding {
  id         String   @id @default(cuid())
  tenantId   String
  documentId String // SpatialChunk's document_id (business id, not FinancialDocument.id)
  chunkId    String // SpatialChunk.chunk_id
  page       Int
  bbox       Json // [x1, y1, x2, y2] -- provenance.bbox
  chunkType  String // SpatialChunk.chunk_type
  text       String   @db.Text // SpatialChunk.text (what's embedded)
  embedding  Unsupported("vector(384)")
  createdAt  DateTime @default(now())

  @@unique([tenantId, documentId, chunkId])
  @@index([tenantId])
  @@index([tenantId, documentId])
}
